# docpod reads keys from this file (copy to .env). Keys are sent ONLY to the
# provider APIs you select in config.toml — never anywhere else.
# You only need keys for the providers you actually use.

# LLM providers (pick one in config.toml: [llm] provider = "anthropic" | "openai")
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# TTS providers (pick one in config.toml: [tts] provider = "elevenlabs" | "openai")
# OpenAI TTS reuses OPENAI_API_KEY above.
ELEVENLABS_API_KEY=
